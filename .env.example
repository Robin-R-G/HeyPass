# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
# REQUIRED: Generate with: openssl rand -base64 32
# Must be at least 32 characters
JWT_SECRET=your_jwt_secret_at_least_32_characters

# Separate secret for refresh tokens (recommended)
# If not set, uses JWT_SECRET
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_characters

# Redis
REDIS_URL=redis://localhost:6379

# Optional: Encryption key for Redis PII storage
# If not set, derives from JWT_SECRET
REDIS_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# QR Security
# REQUIRED: HMAC secret for QR code signing (base64)
QR_HMAC_SECRET=your_qr_hmac_secret

# Billing Encryption
# REQUIRED: AES-256-GCM key for payment gateway credential encryption
# Must be at least 32 characters
BILLING_ENCRYPTION_KEY=your_billing_encryption_key_at_least_32_characters

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@heypass.app
SENDGRID_FROM_NAME=Heypass

# File Upload
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100
